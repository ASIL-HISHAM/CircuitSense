# CircuitSense Environment Configuration
# Copy this file to .env and update with your settings

# API Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# PyTorch Device
DEVICE=auto  # auto | cuda | cpu | mps

# Model Inference
CONFIDENCE_THRESHOLD=0.6

# Data Processing
NUM_WORKERS=4
BATCH_SIZE=128

# Optional: Weights & Biases
WANDB_ENTITY=
WANDB_PROJECT=circuitsense
